---
import BaseLayout from '@/layouts/BaseLayout.astro';
const locale = 'en';
---
<BaseLayout {locale} path="/404" noindex title="Page not found · Paper & Pen" description="The page you are looking for could not be found.">
  <section class="section-pad bg-cream-50 min-h-[60vh] flex items-center">
    <div class="max-w-xl mx-auto text-center">
      <p class="font-display text-7xl font-bold text-copper-400 mb-4">404</p>
      <h1 class="font-display text-3xl font-bold text-ink-500 mb-3">We couldn't find that page</h1>
      <p class="text-ink-500/60 text-lg mb-8">The page may have moved. Let's get you back on track.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="btn-primary">Back to home</a>
        <a href="/free-invoicing-software" class="btn-secondary">Free invoicing software</a>
      </div>
    </div>
  </section>
</BaseLayout>
