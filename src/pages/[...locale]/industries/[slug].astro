---
import { getCollection } from 'astro:content';
import MarketingPage from '@/components/templates/MarketingPage.astro';
import { contentStaticPaths } from '@/lib/paths';
import { useTranslations, type Locale } from '@/i18n';

export async function getStaticPaths() {
  const entries = await getCollection('industries');
  return contentStaticPaths(entries);
}

const { data, locale } = Astro.props as { data: any; locale: Locale };
const t = useTranslations(locale);
---
<MarketingPage {locale} {data} basePath="/industries" section={{ label: t('nav.solutions'), href: '/industries/trading' }} />
