---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/blocks/Breadcrumbs.astro';
import FaqAccordion from '@/components/blocks/FaqAccordion.astro';
import CtaBand from '@/components/blocks/CtaBand.astro';
import { useTranslations, type Locale } from '@/i18n';
import { localeStaticPaths } from '@/lib/paths';
import { graph, organization, faqPage, breadcrumbList } from '@/lib/schema';

export const getStaticPaths = localeStaticPaths;
const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);

const faqs = [
  { q: t('homeFaq.q1'), a: t('homeFaq.a1') },
  { q: t('homeFaq.q2'), a: t('homeFaq.a2') },
  { q: t('homeFaq.q3'), a: t('homeFaq.a3') },
  { q: t('homeFaq.q4'), a: t('homeFaq.a4') },
  { q: t('fi.faq.q1'), a: t('fi.faq.a1') },
  { q: t('fi.faq.q2'), a: t('fi.faq.a2') },
  { q: t('fi.faq.q4'), a: t('fi.faq.a4') },
  { q: t('pricingFaq.q1'), a: t('pricingFaq.a1') },
  { q: t('pricingFaq.q2'), a: t('pricingFaq.a2') },
  { q: t('pricingFaq.q3'), a: t('pricingFaq.a3') },
];
const crumbs = [{ name: 'Home', url: '/' }, { name: 'FAQ', url: '/faq' }];
const jsonld = [graph(organization(), breadcrumbList(crumbs)), graph(faqPage(faqs))];
---
<BaseLayout
  {locale}
  path="/faq"
  title={t('seo.faqTitle')}
  description={t('seo.faqDesc')}
  {jsonld}
>
  <Breadcrumbs {locale} crumbs={[{ name: 'Home', href: '/' }, { name: 'FAQ' }]} />
  <FaqAccordion title={t('faqSection.title')} eyebrow={t('faqSection.eyebrow')} faqs={faqs} bg="white" />
  <CtaBand {locale} />
</BaseLayout>
