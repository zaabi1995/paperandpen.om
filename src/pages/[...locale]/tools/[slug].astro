---
import { getCollection } from 'astro:content';
import ToolPage from '@/components/templates/ToolPage.astro';
import { contentStaticPaths } from '@/lib/paths';
import type { Locale } from '@/i18n';

export async function getStaticPaths() {
  const entries = await getCollection('tools');
  return contentStaticPaths(entries);
}

const { data, locale } = Astro.props as { data: any; locale: Locale };
---
<ToolPage {locale} {data} />
