---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SocialProof from '@/components/blocks/SocialProof.astro';
import ComparisonTable from '@/components/blocks/ComparisonTable.astro';
import FaqAccordion from '@/components/blocks/FaqAccordion.astro';
import CtaBand from '@/components/blocks/CtaBand.astro';
import SubdomainChecker from '@/components/islands/SubdomainChecker.tsx';
import ModulePicker from '@/components/islands/ModulePicker.tsx';
import LangShowcase from '@/components/islands/LangShowcase.tsx';
import { useTranslations, localizePath, isRTL, type Locale } from '@/i18n';
import { localeStaticPaths } from '@/lib/paths';
import { graph, organization, softwareApplication, faqPage } from '@/lib/schema';

export const getStaticPaths = localeStaticPaths;
const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const lp = (p: string) => localizePath(p, locale);
const rtl = isRTL(locale);

const compareCols = [t('compare.pp'), t('compare.zoho'), t('compare.odoo'), t('compare.tally'), t('compare.sowaan')];
const featKeys = ['arabic', 'gcc_pricing', 'free_trial', 'local_support', 'multi_lang', 'paymob', 'onboarding'];
const MATRIX: Record<string, boolean[]> = {
  arabic: [true, false, false, false, true],
  gcc_pricing: [true, false, false, true, true],
  free_trial: [true, true, true, false, false],
  local_support: [true, false, false, false, true],
  multi_lang: [true, false, false, false, false],
  paymob: [true, false, false, false, false],
  onboarding: [true, false, false, false, false],
};
const compareRows = featKeys.map((k) => ({ feature: t(`compare.rows.${k}`), values: MATRIX[k] }));

const homeFaqs = [
  { q: t('homeFaq.q1'), a: t('homeFaq.a1') },
  { q: t('homeFaq.q2'), a: t('homeFaq.a2') },
  { q: t('homeFaq.q3'), a: t('homeFaq.a3') },
  { q: t('homeFaq.q4'), a: t('homeFaq.a4') },
];

const checkerStrings = {
  label: t('hero.subdomainLabel'),
  placeholder: t('hero.subdomainPlaceholder'),
  suffix: t('hero.subdomainSuffix'),
  checking: t('hero.checking'),
  available: t('hero.available_short'),
  taken: t('hero.taken_short'),
  error: t('hero.subdomainError'),
  cta: t('hero.cta'),
};

const moduleStrings = {
  included: t('modules.included'),
  estimateLabel: t('modules.estimateLabel'),
  perMonth: t('modules.omr_mo'),
  baseLabel: t('modules.base_label') + ' · ' + t('pricing.free_label'),
  addonsLabel: t('modules.addons_label'),
  startTrial: t('modules.startTrial'),
  estimateNote: t('modules.estimateNote'),
  titles: { sales: t('modules.sales.title'), inventory: t('modules.inventory.title'), hr: t('modules.hr.title'), accounting: t('modules.accounting.title'), manufacturing: t('modules.manufacturing.title'), reports: t('modules.reports.title') },
  descs: { sales: t('modules.sales.desc'), inventory: t('modules.inventory.desc'), hr: t('modules.hr.desc'), accounting: t('modules.accounting.desc'), manufacturing: t('modules.manufacturing.desc'), reports: t('modules.reports.desc') },
};

const jsonld = [graph(organization(), softwareApplication()), graph(faqPage(homeFaqs.map((f) => ({ q: f.q, a: f.a }))))];
const title = t('seo.homeTitle');
const description = t('seo.homeDesc');
const keywords = 'free ERP, cloud ERP, free invoicing software, online invoicing, accounting software, Arabic ERP, multi-currency invoicing, ERP Oman, ERP GCC, Paper and Pen ERP, Paymob';
---

<BaseLayout {locale} path="/" {title} {description} {keywords} {jsonld}>
  {/* Hero — bold modern SaaS */}
  <section class="relative overflow-hidden bg-mesh-dark text-cream-50 pt-28 pb-28 lg:pt-32 lg:pb-36" dir={rtl ? 'rtl' : 'ltr'}>
    <div class="absolute inset-0 bg-grid pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto px-6 lg:px-10 grid lg:grid-cols-[1.05fr_1fr] gap-14 items-center">
      <div>
        <div class="inline-flex items-center gap-2 glass text-copper-300 text-xs font-semibold px-3.5 py-1.5 rounded-full mb-7 tracking-widest uppercase">
          <span class="w-1.5 h-1.5 rounded-full bg-copper-400 animate-pulse"></span>{t('hero.badge')}
        </div>
        <h1 class="font-display text-5xl lg:text-6xl xl:text-7xl font-bold leading-[1.04] mb-6">
          {t('hero.tagline_line1')}<br /><span class="text-gradient">{t('hero.tagline_line2')}</span>
        </h1>
        <p class="text-cream-100/70 text-lg leading-relaxed mb-7 max-w-lg">{t('hero.sub')}</p>

        <div class="bg-white rounded-2xl p-4 shadow-2xl shadow-black/40 max-w-md">
          <SubdomainChecker client:load strings={checkerStrings} signupBase={lp('/signup')} rtl={rtl} />
        </div>
        <p class="mt-4 text-xs text-cream-100/40 tracking-wide">{t('hero.trialNote')}</p>

        <div class="mt-7 flex items-center gap-3">
          <div class="flex text-copper-300">
            {[0,1,2,3,4].map(() => <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}
          </div>
          <span class="text-sm text-cream-100/70"><b class="text-cream-50">4.9/5</b> · {t('proof.ratingCount')}</span>
        </div>
      </div>

      {/* Floating product mockup */}
      <div class="hidden lg:block relative">
        <div class="absolute -inset-10 bg-copper-400/20 blur-3xl rounded-full pointer-events-none"></div>
        <div class="relative rounded-3xl bg-white shadow-2xl shadow-black/50 border border-white/10 overflow-hidden rotate-1">
          <div class="bg-ink-700 px-5 py-3 flex items-center justify-between">
            <span class="text-cream-50/90 text-sm font-semibold font-display">{t('hero.card_title')}</span>
            <div class="flex gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-white/20"></span><span class="w-2.5 h-2.5 rounded-full bg-white/20"></span><span class="w-2.5 h-2.5 rounded-full bg-copper-400"></span></div>
          </div>
          <div class="p-5">
            <div class="flex items-end justify-between mb-1"><span class="text-xs text-ink-400 font-medium">{t('hero.stat1_label')}</span></div>
            <div class="flex items-end gap-2 mb-4"><span class="font-display text-3xl font-bold text-ink-500">{t('hero.stat1_value')}</span><span class="text-xs font-semibold text-emerald-600 mb-1">▲ 18%</span></div>
            <div class="flex items-end gap-1.5 h-20 mb-5">
              {[42,58,49,71,63,88,76,95].map((h) => <div class="flex-1 rounded-t-md bg-gradient-to-t from-ink-500 to-copper-400" style={`height:${h}%`}></div>)}
            </div>
            <div class="grid grid-cols-2 gap-3 mb-4">
              <div class="rounded-xl bg-cream-50 border border-cream-100 p-3"><p class="text-[10px] text-ink-400 uppercase tracking-wide">{t('hero.stat2_label')}</p><p class="text-lg font-bold text-ink-500">{t('hero.stat2_value')}</p></div>
              <div class="rounded-xl bg-cream-50 border border-cream-100 p-3"><p class="text-[10px] text-ink-400 uppercase tracking-wide">{t('hero.stat3_label')}</p><p class="text-lg font-bold text-copper-500">{t('hero.stat3_value')}</p></div>
            </div>
            <div class="h-1.5 w-full bg-cream-100 rounded-full overflow-hidden"><div class="h-full w-3/4 bg-gradient-to-r from-ink-500 to-copper-400 rounded-full"></div></div>
          </div>
        </div>
        {/* floating badges */}
        <div class="absolute -top-5 -start-6 bg-white rounded-xl shadow-xl px-3.5 py-2.5 flex items-center gap-2 -rotate-3">
          <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-emerald-100 text-emerald-600"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg></span>
          <div><p class="text-[10px] text-ink-400 leading-none mb-0.5">Invoice paid</p><p class="text-xs font-bold text-ink-500 leading-none">1,250.000 OMR</p></div>
        </div>
        <div class="absolute -bottom-6 -end-4 bg-white rounded-xl shadow-xl px-3.5 py-2.5 flex items-center gap-2 rotate-2">
          <span class="text-lg">🇴🇲</span>
          <div><p class="text-[10px] text-ink-400 leading-none mb-0.5">5 languages</p><p class="text-xs font-bold text-ink-500 leading-none">AR · EN · HI · BN · UR</p></div>
        </div>
      </div>
    </div>
  </section>

  {/* Stat band */}
  <section class="bg-ink-900 text-cream-50 border-t border-white/5">
    <div class="max-w-6xl mx-auto px-6 lg:px-10 py-10 grid grid-cols-2 lg:grid-cols-4 gap-8">
      {[
        { v: t('trust.stat2_value'), l: t('trust.stat2_label') },
        { v: '5', l: t('trust.stat1_label') },
        { v: t('trust.stat3_value'), l: t('trust.stat3_label') },
        { v: t('trust.stat4_value'), l: t('trust.stat4_label') },
      ].map((s) => (
        <div class="text-center lg:text-start">
          <p class="font-display text-3xl lg:text-4xl font-bold text-gradient">{s.v}</p>
          <p class="text-cream-100/55 text-sm mt-1">{s.l}</p>
        </div>
      ))}
    </div>
  </section>

  {/* Language showcase */}
  <section class="section-pad bg-cream-50 border-b border-cream-200">
    <div class="container-narrow">
      <div class="max-w-2xl mb-12 reveal">
        <p class="eyebrow mb-3">{t('languages.eyebrow')}</p>
        <h2 class="font-display text-3xl lg:text-4xl font-bold text-ink-500 leading-tight mb-4">{t('languages.title')}</h2>
        <p class="text-ink-500/75 text-lg leading-relaxed">{t('languages.sub')}</p>
      </div>
      <LangShowcase client:visible />
    </div>
  </section>

  {/* Modules */}
  <section id="modules" class="section-pad bg-white">
    <div class="container-wide">
      <div class="max-w-2xl mb-14 reveal">
        <p class="eyebrow mb-3">{t('modules.eyebrow')}</p>
        <h2 class="font-display text-3xl lg:text-5xl font-bold text-ink-500 leading-tight mb-4">{t('modules.title')}</h2>
        <p class="text-ink-500/75 text-lg leading-relaxed">{t('modules.sub')}</p>
      </div>
      <ModulePicker client:visible strings={moduleStrings} signupBase={lp('/signup')} />
    </div>
  </section>

  {/* Compare */}
  <ComparisonTable eyebrow={t('compare.eyebrow')} title={t('compare.title')} cols={compareCols} rows={compareRows} bg="cream" />

  {/* FAQ */}
  <FaqAccordion eyebrow={t('faqSection.eyebrow')} title={t('faqSection.title')} faqs={homeFaqs} bg="white" />

  <CtaBand {locale} />
</BaseLayout>
