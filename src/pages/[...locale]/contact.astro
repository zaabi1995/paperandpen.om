---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/blocks/Breadcrumbs.astro';
import { useTranslations, type Locale } from '@/i18n';
import { localeStaticPaths } from '@/lib/paths';
import { graph, organization, breadcrumbList } from '@/lib/schema';

export const getStaticPaths = localeStaticPaths;
const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const crumbs = [{ name: 'Home', url: '/' }, { name: t('footer.contact'), url: '/contact' }];
const jsonld = [graph(organization(), breadcrumbList(crumbs))];
---
<BaseLayout {locale} path="/contact" title={t('seo.contactTitle')} description={t('seo.contactDesc')} {jsonld}>
  <Breadcrumbs {locale} crumbs={[{ name: 'Home', href: '/' }, { name: t('footer.contact') }]} />
  <section class="section-pad bg-cream-50">
    <div class="max-w-2xl mx-auto text-center">
      <h1 class="font-display text-4xl lg:text-5xl font-bold text-ink-500 mb-5">{t('pages.contact.title')}</h1>
      <p class="text-ink-500/65 text-lg leading-relaxed mb-10">{t('pages.contact.lead')}</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="https://api.whatsapp.com/send?phone=96898899100" target="_blank" rel="noopener noreferrer" class="btn-copper">{t('pages.contact.whatsapp')}</a>
        <a href="mailto:info@paperandpen.om" class="btn-secondary">{t('pages.contact.email')}</a>
      </div>
      <p class="text-sm text-ink-400 mt-6">{t('pages.contact.hours')}</p>
    </div>
  </section>
</BaseLayout>
