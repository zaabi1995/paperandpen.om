---
import { getCollection } from 'astro:content';
import ComparePage from '@/components/templates/ComparePage.astro';
import { contentStaticPaths } from '@/lib/paths';
import type { Locale } from '@/i18n';

export async function getStaticPaths() {
  const entries = await getCollection('comparisons');
  return contentStaticPaths(entries);
}

const { data, locale } = Astro.props as { data: any; locale: Locale };
---
<ComparePage {locale} {data} />
