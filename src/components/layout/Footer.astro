---
import { useTranslations, localizePath, type Locale } from '@/i18n';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
const lp = (p: string) => localizePath(p, locale);
const year = 2026;

const cols = [
  {
    title: t('footer.product'),
    links: [
      { href: '/free-invoicing-software', label: t('footer.freeInvoicing') },
      { href: '/features/invoicing', label: t('mega.invoicing') },
      { href: '/features/accounting', label: t('mega.accounting') },
      { href: '/pricing', label: t('nav.pricing') },
      { href: '/compare/paperandpen-vs-zoho', label: t('nav.compare') },
    ],
  },
  {
    title: t('footer.tools'),
    links: [
      { href: '/tools/free-invoice-generator', label: t('mega.invoiceGen') },
      { href: '/tools/free-quotation-generator', label: t('mega.quotationGen') },
      { href: '/tools/free-receipt-generator', label: t('mega.receiptGen') },
      { href: '/tools/oman-vat-calculator', label: t('mega.vatCalc') },
      { href: '/tools', label: t('mega.allTools') },
    ],
  },
  {
    title: t('footer.company'),
    links: [
      { href: '/about', label: t('footer.about') },
      { href: '/blog', label: t('footer.blog') },
      { href: '/contact', label: t('footer.contact') },
      { href: '/security', label: t('footer.security') },
    ],
  },
  {
    title: t('footer.legal'),
    links: [
      { href: '/terms', label: t('footer.terms') },
      { href: '/privacy', label: t('footer.privacy') },
    ],
  },
];
---

<footer class="bg-ink-900 text-cream-100/50 relative overflow-hidden">
  <div class="absolute inset-0 bg-paper-texture opacity-20 pointer-events-none"></div>
  <div class="relative max-w-7xl mx-auto px-6 lg:px-10 pt-16 pb-8">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-10 mb-14">
      <div class="col-span-2">
        <img src="/logo-white.svg" alt="Paper & Pen ERP" class="h-9 w-auto mb-5 opacity-90" width="120" height="36" />
        <p class="text-sm leading-relaxed max-w-xs mb-6">{t('footer.tagline')}</p>
        <a
          href="https://api.whatsapp.com/send?phone=96898899100"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm text-copper-300 hover:text-copper-200 font-medium transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.693.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          +968 9889 9100
        </a>
      </div>

      {cols.map((col) => (
        <div>
          <h3 class="text-cream-100 text-sm font-semibold mb-4 tracking-wide">{col.title}</h3>
          <ul class="space-y-2.5">
            {col.links.map((l) => (
              <li><a href={lp(l.href)} class="text-sm hover:text-cream-100 transition-colors">{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-center sm:text-start">{t('footer.rights', { year })}</p>
      <div class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
        <span class="text-xs">{t('footer.status')}</span>
      </div>
    </div>
  </div>
</footer>
