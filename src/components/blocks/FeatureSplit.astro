---
import Icon from './Icon.astro';

interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  items?: string[];
  flip?: boolean;
  bg?: 'white' | 'cream';
}
const { eyebrow, title, body, items = [], flip = false, bg = 'white' } = Astro.props;
---
<section class={`section-pad ${bg === 'cream' ? 'bg-cream-50' : 'bg-white'}`}>
  <div class="container-narrow grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
    <div class={`reveal ${flip ? 'lg:order-2' : ''}`}>
      {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
      <h2 class="font-display text-3xl lg:text-4xl font-bold text-ink-500 leading-tight mb-5">{title}</h2>
      {body && <p class="text-ink-500/60 text-lg leading-relaxed mb-6">{body}</p>}
      {items.length > 0 && (
        <ul class="space-y-3">
          {items.map((it) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 shrink-0 inline-flex items-center justify-center w-5 h-5 rounded-full bg-emerald-100 text-emerald-600">
                <Icon name="check" class="w-3.5 h-3.5" />
              </span>
              <span class="text-ink-500/80 leading-relaxed">{it}</span>
            </li>
          ))}
        </ul>
      )}
    </div>

    {/* Decorative editorial panel */}
    <div class={`reveal ${flip ? 'lg:order-1' : ''}`}>
      <div class="relative aspect-[4/3] rounded-2xl bg-gradient-to-br from-ink-500 to-ink-700 overflow-hidden shadow-2xl shadow-ink-500/20">
        <div class="absolute inset-0 bg-paper-texture opacity-30"></div>
        <div class="absolute top-6 end-6 w-40 h-40 rounded-full bg-copper-400/20 blur-2xl"></div>
        <div class="absolute inset-0 p-8 flex flex-col justify-center gap-3">
          <div class="bg-white/10 backdrop-blur rounded-xl p-4 border border-white/10">
            <div class="h-2 w-1/3 bg-copper-300/60 rounded-full mb-3"></div>
            <div class="h-2 w-full bg-white/20 rounded-full mb-2"></div>
            <div class="h-2 w-4/5 bg-white/15 rounded-full"></div>
          </div>
          <div class="grid grid-cols-3 gap-3">
            {[0, 1, 2].map(() => (
              <div class="bg-white/10 rounded-lg p-3 border border-white/10">
                <div class="h-1.5 w-2/3 bg-white/20 rounded mb-2"></div>
                <div class="h-3 bg-copper-300/40 rounded"></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
