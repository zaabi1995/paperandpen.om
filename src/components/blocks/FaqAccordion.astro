---
interface Faq { q: string; a: string }
interface Props { title?: string; eyebrow?: string; faqs: Faq[]; bg?: 'white' | 'cream' }
const { title, eyebrow, faqs, bg = 'cream' } = Astro.props;
---
<section class={`section-pad ${bg === 'cream' ? 'bg-cream-50 border-y border-cream-200' : 'bg-white'}`}>
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-12 reveal">
      {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
      <h2 class="font-display text-3xl lg:text-4xl font-bold text-ink-500">{title}</h2>
    </div>
    <div class="space-y-3">
      {faqs.map((f) => (
        <details class="reveal group bg-white border border-cream-200 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none font-semibold text-ink-500">
            <span>{f.q}</span>
            <svg class="w-5 h-5 shrink-0 text-copper-400 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          </summary>
          <div class="px-5 pb-5 text-ink-500/70 leading-relaxed">{f.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>
<style>
  details > summary::-webkit-details-marker { display: none; }
</style>
