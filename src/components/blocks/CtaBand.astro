---
import { useTranslations, localizePath, type Locale } from '@/i18n';
interface Props { locale: Locale; title?: string; sub?: string }
const { locale, title, sub } = Astro.props;
const t = useTranslations(locale);
const lp = (p: string) => localizePath(p, locale);
---
<section class="section-pad bg-ink-500 relative overflow-hidden">
  <div class="absolute inset-0 bg-paper-texture opacity-30 pointer-events-none"></div>
  <div class="absolute top-0 end-0 w-96 h-96 bg-copper-400/10 blur-3xl rounded-full pointer-events-none"></div>
  <div class="relative max-w-3xl mx-auto text-center reveal">
    <h2 class="font-display text-3xl lg:text-4xl font-bold text-cream-50 leading-tight mb-4">{title ?? t('cta.title')}</h2>
    <p class="text-cream-100/65 text-lg leading-relaxed mb-8">{sub ?? t('cta.sub')}</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href={lp('/signup')} class="btn-copper">{t('trust.cta')}
        <svg class="w-4 h-4 rtl:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7-7l7 7-7 7"/></svg>
      </a>
      <a href={lp('/pricing')} class="inline-flex items-center justify-center px-7 py-3.5 border-2 border-white/20 text-cream-50 font-semibold rounded-xl hover:bg-white/10 transition-all">{t('nav.pricing')}</a>
    </div>
    <p class="mt-5 text-xs text-cream-100/40 tracking-wide">{t('hero.trialNote')}</p>
  </div>
</section>
