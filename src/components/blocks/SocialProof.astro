---
import { useTranslations, type Locale } from '@/i18n';
interface Props { locale: Locale; compact?: boolean }
const { locale, compact = false } = Astro.props;
const t = useTranslations(locale);

const stats = [
  { value: '4.9/5', label: t('proof.rating') },
  { value: '5', label: t('trust.stat1_label') },
  { value: t('trust.stat3_value'), label: t('trust.stat3_label') },
  { value: 'OMR', label: t('trust.stat4_label') },
];
---
{compact ? (
  <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 py-6">
    <div class="flex items-center gap-2">
      <div class="flex text-copper-400">
        {[0,1,2,3,4].map(() => <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}
      </div>
      <span class="text-sm font-semibold text-ink-500">4.9/5</span>
      <span class="text-sm text-ink-400">· {t('proof.ratingCount')}</span>
    </div>
    <span class="text-sm text-ink-400">{t('proof.builtInOman')}</span>
  </div>
) : (
  <section class="section-pad bg-white">
    <div class="container-narrow">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
        {stats.map((s) => (
          <div class="reveal text-center p-6 rounded-2xl bg-cream-50 border border-cream-200">
            <p class="font-display text-3xl lg:text-4xl font-bold text-copper-500 mb-2">{s.value}</p>
            <p class="text-ink-400 text-sm leading-snug">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
