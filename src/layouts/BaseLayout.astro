---
import '@/styles/global.css';
import Seo from '@/components/Seo.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import StickyCta from '@/components/blocks/StickyCta.astro';
import { isRTL, LOCALE_META, type Locale } from '@/i18n';

export interface Props {
  title: string;
  description: string;
  path: string;
  locale: Locale;
  image?: string;
  jsonld?: Record<string, unknown>[];
  noindex?: boolean;
  keywords?: string;
  /** Hide chrome (nav/footer/sticky CTA) for bare pages like signup/login. */
  bare?: boolean;
}

const { locale, bare = false, ...seo } = Astro.props;
const dir = isRTL(locale) ? 'rtl' : 'ltr';
const htmlLang = LOCALE_META[locale].htmlLang;
---

<!doctype html>
<html lang={htmlLang} dir={dir} data-product="paperandpen">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#172e50" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="apple-touch-icon" href="/logo.svg" />
    <link rel="manifest" href="/manifest.json" />

    {/* Fonts — fonts.bhd.om only (never Google) */}
    <link rel="preconnect" href="https://fonts.bhd.om" />
    <link rel="preconnect" href="https://fonts.bhd.om" crossorigin />
    <link
      href="https://fonts.bhd.om/css2?family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,600;1,700&family=DM+Sans:wght@300;400;500;600;700&family=IBM+Plex+Arabic:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <Seo {...seo} locale={locale} />
  </head>
  <body>
    {!bare && <Navbar locale={locale} />}
    <main class="flex-1">
      <slot />
    </main>
    {!bare && <Footer locale={locale} />}
    {!bare && <StickyCta locale={locale} />}

    {/* Reveal-on-scroll (progressive enhancement) */}
    <script>
      const els = document.querySelectorAll('.reveal');
      const revealAll = () => els.forEach((el) => el.classList.add('is-visible'));
      if ('IntersectionObserver' in window && els.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '200px 0px 200px 0px' }
        );
        els.forEach((el) => io.observe(el));
        // Safety net: never leave content hidden if the observer never fires.
        window.addEventListener('load', () => setTimeout(revealAll, 1500));
      } else {
        revealAll();
      }
    </script>
  </body>
</html>
